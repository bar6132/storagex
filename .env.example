# ─── JWT ────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_random_64_char_hex_string

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=user
POSTGRES_PASSWORD=change_me_db_password
POSTGRES_DB=transcodex

# ─── MinIO / S3 ──────────────────────────────────────────────────────────────
MINIO_ROOT_USER=change_me_minio_user
MINIO_ROOT_PASSWORD=change_me_minio_password

# ─── RabbitMQ ────────────────────────────────────────────────────────────────
RABBITMQ_DEFAULT_USER=change_me_rabbit_user
RABBITMQ_DEFAULT_PASS=change_me_rabbit_password

# ─── Internal service secret ─────────────────────────────────────────────────
# Shared between the API and workers to authenticate /internal/notify calls.
INTERNAL_NOTIFY_SECRET=change_me_internal_secret

# ─── Cookie security ─────────────────────────────────────────────────────────
# Set to "true" in production (requires HTTPS). Leave "false" for local HTTP dev.
COOKIE_SECURE=false

# ─── Seed users ──────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change_me_admin_password
SEED_USER_EMAIL=user@example.com
SEED_USER_PASSWORD=change_me_user_password
SEED_PERSONAL_ADMIN_EMAIL=your@gmail.com
SEED_PERSONAL_ADMIN_PASSWORD=change_me_personal_admin_password

# ─── Ports & URLs ────────────────────────────────────────────────────────────
# Backend runs on port 8002, frontend on port 3002.
#
# LOCAL access only:
#   NEXT_PUBLIC_API_URL=http://localhost:8002
#   CORS_ORIGINS=http://localhost:3002
#
# TAILSCALE / remote access:
#   Replace <TAILSCALE_IP> with your Tailscale IP (e.g. 100.64.0.1)
NEXT_PUBLIC_API_URL=http://100.78.219.101:8002
CORS_ORIGINS=http://localhost:3002,http://100.78.219.101:3002

# NEXT_PUBLIC_API_URL=http://localhost:8002
# CORS_ORIGINS=http://localhost:3002
